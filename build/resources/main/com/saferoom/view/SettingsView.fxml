<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXSlider?>
<?import com.jfoenix.controls.JFXToggleButton?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="content-scroll-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.saferoom.controller.SettingsController">
    <content>
        <VBox styleClass="page-container" spacing="30.0">
            <children>
                <!-- Profile Section -->
                <VBox spacing="15.0">
                    <children>
                        <Label styleClass="settings-section-title" text="Profile" />
                        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="setting-row">
                            <children>
                                <Label styleClass="user-avatar" text="U" />
                                <VBox>
                                    <children>
                                        <Label styleClass="setting-title" text="Username" />
                                        <Label styleClass="setting-description" text="user@saferoom.com" />
                                    </children>
                                </VBox>
                                <Pane HBox.hgrow="ALWAYS" />
                                <Hyperlink text="Change Avatar" styleClass="signup-link" />
                            </children>
                        </HBox>
                        <Separator styleClass="settings-separator" />
                    </children>
                </VBox>

                <!-- Privacy & Security Section -->
                <VBox spacing="15.0">
                    <children>
                        <Label styleClass="settings-section-title" text="Privacy &amp; Security" />
                        <HBox alignment="CENTER_LEFT" styleClass="setting-row">
                            <children>
                                <VBox>
                                    <children>
                                        <Label styleClass="setting-title" text="Two-Factor Authentication" />
                                        <Label styleClass="setting-description" text="Add an extra layer of security to your account" />
                                    </children>
                                </VBox>
                                <Pane HBox.hgrow="ALWAYS" />
                                <JFXToggleButton fx:id="twoFaToggle" styleClass="settings-toggle" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" styleClass="setting-row">
                            <children>
                                <VBox>
                                    <children>
                                        <Label styleClass="setting-title" text="End-to-End Encryption" />
                                        <Label styleClass="setting-description" text="Enable automatic encryption for all communications" />
                                    </children>
                                </VBox>
                                <Pane HBox.hgrow="ALWAYS" />
                                <JFXToggleButton fx:id="e2eToggle" selected="true" styleClass="settings-toggle" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" styleClass="setting-row">
                            <children>
                                <VBox>
                                    <children>
                                        <Label styleClass="setting-title" text="Show Online Status" />
                                        <Label styleClass="setting-description" text="Let your friends see when you are online" />
                                    </children>
                                </VBox>
                                <Pane HBox.hgrow="ALWAYS" />
                                <JFXToggleButton fx:id="onlineStatusToggle" selected="true" styleClass="settings-toggle" />
                            </children>
                        </HBox>
                        <Separator styleClass="settings-separator" />
                    </children>
                </VBox>

                <!-- Notifications Section -->
                <VBox spacing="15.0">
                    <children>
                        <Label styleClass="settings-section-title" text="Notifications" />
                        <HBox alignment="CENTER_LEFT" styleClass="setting-row">
                            <children>
                                <VBox>
                                    <children>
                                        <Label styleClass="setting-title" text="Desktop Notifications" />
                                        <Label styleClass="setting-description" text="Receive notifications for new messages and calls" />
                                    </children>
                                </VBox>
                                <Pane HBox.hgrow="ALWAYS" />
                                <JFXToggleButton fx:id="desktopNotificationToggle" selected="true" styleClass="settings-toggle" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" styleClass="setting-row">
                            <children>
                                <VBox>
                                    <children>
                                        <Label styleClass="setting-title" text="Sound Notifications" />
                                        <Label styleClass="setting-description" text="Play a sound for notifications" />
                                    </children>
                                </VBox>
                                <Pane HBox.hgrow="ALWAYS" />
                                <JFXToggleButton fx:id="soundNotificationToggle" selected="true" styleClass="settings-toggle" />
                            </children>
                        </HBox>
                        <VBox spacing="10.0" styleClass="setting-row">
                            <children>
                                <Label styleClass="setting-title" text="Notification Volume" />
                                <JFXSlider fx:id="volumeSlider" value="75.0" styleClass="settings-slider" />
                            </children>
                        </VBox>
                        <Separator styleClass="settings-separator" />
                    </children>
                </VBox>

                <!-- Danger Zone Section -->
                <VBox spacing="15.0">
                    <children>
                        <Label styleClass="settings-section-title-danger" text="Danger Zone" />
                        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="setting-row">
                            <children>
                                <Button fx:id="clearDataButton" styleClass="danger-button" text="Clear All Data" />
                                <Button fx:id="deleteAccountButton" styleClass="danger-button" text="Delete Account" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
